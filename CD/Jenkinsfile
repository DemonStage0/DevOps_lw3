pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('DevOps_lw3')
        LC_ALL = "en_US.UTF-8"
        LANG = "en_US.UTF-8"
        LANGUAGE = "en_US.UTF-8"
    }

    options {
        timestamps()
        skipDefaultCheckout(true)
    }

    triggers {
        upstream(upstreamProjects: 'DevOps_lw3_CI', threshold: hudson.model.Result.SUCCESS)
    }

    stages {
        stage('Clone repository') {
            steps {
                cleanWs()
                bat 'chcp 65001 && git clone -b main https://github.com/DemonStage0/DevOps_lw3.git'
            }
        }

        stage('Login to DockerHub') {
            steps {
                bat 'chcp 65001 && docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }

        stage('Pull image from DockerHub') {
            steps {
                bat 'chcp 65001 && docker pull demonstage/devops_lw3:latest'
            }
        }

        stage('Start services') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw3 && docker-compose up -d'
            }
        }

        stage('Wait for services') {
            steps {
                bat 'chcp 65001 && ping -n 21 127.0.0.1 > nul'
            }
        }

        stage('Run unit tests') {
            steps {
                bat '''
                    chcp 65001
                    cd DevOps_lw3
                    for /f "tokens=*" %%i in ('docker ps -qf "name=^devops_lw3-web"') do set containerId=%%i
                    IF "%containerId%" == "" (
                        echo "No web container running"
                        exit 1
                    ) ELSE (
                        echo Running unit tests...
                        docker exec %containerId% python -m pytest src/unit_tests/ -v
                    )
                '''
            }
        }

        stage('Functional test - Health check') {
            steps {
                bat 'chcp 65001 && curl -s http://localhost:8000/'
            }
        }

        stage('Functional test - Train model') {
            steps {
                bat 'chcp 65001 && curl -s http://localhost:8000/train'
            }
        }

        stage('Functional test - Predict') {
            steps {
                bat 'chcp 65001 && curl -s "http://localhost:8000/predict?RI=1.52101&Na=13.64&Mg=4.49&Al=1.1&Si=71.78&K=0.06&Ca=8.75&Ba=0.0&Fe=0.0"'
            }
        }
    }

    post {
        always {
            bat 'chcp 65001 && cd DevOps_lw3 && docker-compose down -v && docker logout'
        }
        success {
            echo 'CD Pipeline completed successfully!'
        }
        failure {
            echo 'CD Pipeline failed! Check logs.'
        }
    }
}